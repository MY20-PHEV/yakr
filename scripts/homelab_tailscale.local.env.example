# Private homelab settings — copy to homelab_tailscale.local.env (gitignored).
#
#   cp scripts/homelab_tailscale.local.env.example scripts/homelab_tailscale.local.env

HOMELAB_TAILSCALE_IP=100.x.x.x
HOMELAB_SSH_USER=your-ssh-user

CHARLIE_WRAP_SECRET=
DENNIS_WRAP_SECRET=

# Optional overrides
# CHARLIE_URL=https://100.x.x.x:8090
# DENNIS_URL=https://100.x.x.x:8091
# ALICE_OPS_PORT=8092
# YAKR_LEGACY_GET_FETCH=1

# Website (Traefik on homelab — see scripts/homelab_website_deploy.sh)
# YAKR_WEBSITE_HOST=yakr.co.uk
# YAKR_WEBSITE_REMOTE_PATH=yakr-website
